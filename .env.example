# ---- Existing 250 Acts of Service app ----
ADMIN_PASSWORD=changeme
SESSION_SECRET=change-this-to-a-random-32-char-secret
DATABASE_PATH=./data/acts.db

# ---- Upriver Fire Relief signup (Supabase) ----
# Public values, safe to expose to the browser. Used by the public form.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. Used by /api/submissions to read all submissions.
# NEVER expose this to the browser. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: the admin route falls back to NEXT_PUBLIC_SUPABASE_URL if unset.
# SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# ADMIN_PASSWORD above also gates the relief admin page at
# /emergency-signup/admin. The same password is shared with the existing
# admin panel. Set a separate value only if you intentionally want one.
